        },
        {
          "address": "aws_cloudfront_distribution.wordpress",
          "type": "aws_cloudfront_distribution", "name": "wordpress",
          "expressions": {
            "origin": {
              "domain_name": { "references": ["aws_lb.wordpress"] }
            }
          }
        },
        {
          "address": "aws_route53_record.wordpress",
          "type": "aws_route53_record", "name": "wordpress",
          "expressions": {
