        {
          "address": "aws_lb.internal",
          "type": "aws_lb", "name": "internal",
          "expressions": {
            "subnets": { "references": ["aws_vpc.banking"] }
          }
        },
        {
          "address": "aws_db_instance.auth_service_db",
          "type": "aws_db_instance", "name": "auth_service_db",
