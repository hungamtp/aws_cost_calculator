            "kms_key_id":           { "references": ["aws_kms_key.banking_storage"] }
          }
        },
        {
          "address": "aws_cloudtrail.banking_audit",
          "type": "aws_cloudtrail", "name": "banking_audit",
          "expressions": {
            "s3_bucket_name": { "references": ["aws_s3_bucket.terraform_state"] }
          }
        }
      ]
